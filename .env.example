# ################################################################
# BRUNO VERIFIES - ENVIRONMENT TEMPLATE
# ################################################################

# --- DISCORD CONFIGURATION ---
# Your Bot's Token (from Discord Developer Portal)
DISCORD_BOT_TOKEN=
# Bot Application ID
DISCORD_CLIENT_ID=
# Bot Client Secret
DISCORD_CLIENT_SECRET=
# (Optional) Public Key
DISCORD_PUBLIC_KEY=
# The ID of your Discord Server (Guild)
DISCORD_GUILD_ID=
# The ID(s) of the role(s) allowed to use /manage (Comma-separated)
DISCORD_ADMIN_ROLE_ID=
# Comma-separated list of Role IDs allowed to use approval buttons
ALLOWED_MOD_ROLE_IDS=
# (Legacy Fallback) The ID of the role to assign to verified users
DISCORD_ROLE_ID=
# (Legacy Fallback) The ID of the "Certified" role
DISCORD_CERTIFIED_ROLE_ID=
# Discord Webhook URL for logs (e.g., #verifications-logs)
DISCORD_LOG_WEBHOOK=

# --- SUPABASE CONFIGURATION ---
# Your Supabase Project URL
SUPABASE_URL=
# Service Role Key (Found in Supabase Settings > API)
SUPABASE_SERVICE_ROLE_KEY=
# Project URL (Frontend accessible)
NEXT_PUBLIC_SUPABASE_URL=
# Anon Key (Frontend accessible)
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# --- EMAIL CONFIGURATION (RESEND) ---
# Your Resend.com API Key
RESEND_API_KEY=

# --- WEBSITE CONFIGURATION ---
# The full URL of your deployment (e.g., https://verify.mycollege.edu)
NEXTAUTH_URL=
# (Optional) Random secret for NextAuth sessions
NEXTAUTH_SECRET=

# --- IMAGE VERIFICATION (OCR) ---
# (Optional) OCR.space API Key for /ivy-verify image processing
OCR_SPACE_API_KEY=
# The ID of the channel where moderators review acceptance letters
MOD_REVIEW_CHANNEL_ID=
